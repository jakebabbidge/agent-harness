{
  "name": "agent-harness",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI tool that wraps coding agents to provide standardised prompt management, isolated execution, and workflow orchestration.",
  "bin": {
    "agent-harness": "./dist/main.js"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
